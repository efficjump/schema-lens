# Server-side endpoint for a Responses-style or Chat Completions-style JSON API.
# Use HTTPS except when connecting to localhost during development.
LLM_API_URL=

# Model identifier understood by the configured endpoint.
LLM_MODEL=

# Optional. Leave empty when the endpoint does not require Bearer authentication.
LLM_API_KEY=

# Optional: responses (default) or chat-completions.
LLM_API_STYLE=responses

# Optional per-runtime cost guard. Set 0 to disable (default: 12/minute).
LLM_RATE_LIMIT_PER_MINUTE=12
